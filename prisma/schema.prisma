// Prisma schema — โครงการแก้ไขปัญหาความยากจน (กข.คจ.)
// อ้างอิงโครงสร้างจากสมุดบัญชี 4 เล่ม:
//   เล่มม่วง   = สมุดบัญชีทะเบียนครัวเรือนเป้าหมาย
//   เล่มน้ำตาล = สมุดบันทึกสถานะหมู่บ้าน
//   เล่มเขียว  = บัญชีคุมเงินฝากธนาคาร
//   เล่มเหลือง = บัญชีคุมลูกหนี้

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// โครงสร้างเขตการปกครอง (Hierarchy): ภาค -> จังหวัด -> อำเภอ -> ตำบล -> หมู่บ้าน
// ใช้เป็นฐานสำหรับการจำกัดขอบเขตข้อมูล (data scope) ตามบทบาทผู้ใช้งาน
// และการรวบรวมสถิติ/รายงานข้ามหมู่บ้านในระบบรวมศูนย์ระดับประเทศ
// ============================================================

model Region {
  id        Int        @id @default(autoincrement())
  name      String     @unique // เช่น ภาคเหนือ, ภาคกลาง, ภาคตะวันออกเฉียงเหนือ, ภาคใต้
  provinces Province[]
}

model Province {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  code     String? @unique // รหัสจังหวัดทางการ 2 หลัก (เช่น "10" = กรุงเทพมหานคร) ตาม Location Code ของ
  // MasterAddress Thailand.xlsx — null ได้สำหรับจังหวัดทดสอบที่ไม่มีรหัสทางการจริง ใช้เป็นกุญแจเชื่อมโยงหลัก
  // ตอน import (ดู prisma/importMasterAddress.mjs) แทนการจับคู่ด้วยชื่อ เพื่อกันข้อมูลซ้ำถ้าชื่อทางการเปลี่ยนในอนาคต
  regionId Int
  region   Region @relation(fields: [regionId], references: [id])

  districts  District[]
  scopeUsers User[]     @relation("UserProvinceScope")
}

model District {
  id         Int      @id @default(autoincrement())
  name       String
  code       String? @unique // รหัสอำเภอทางการ 4 หลัก (จังหวัด 2 หลัก + อำเภอ 2 หลักในจังหวัดนั้น) เช่น "1001"
  // = เขตพระนคร — เป็น prefix ของ SubDistrict.code เสมอ ดูคอมเมนต์ที่ Province.code
  provinceId Int
  province   Province @relation(fields: [provinceId], references: [id])

  subDistricts SubDistrict[]

  scopeUsers User[] @relation("UserDistrictScope")

  @@unique([provinceId, name])
}

model SubDistrict {
  id         Int      @id @default(autoincrement())
  name       String
  code       String? @unique // Location Code ทางการเต็ม 6 หลัก (จังหวัด 2 + อำเภอ 2 + ตำบล 2) เช่น "100101"
  // = แขวงพระบรมมหาราชวัง — ดูคอมเมนต์ที่ Province.code
  districtId Int
  district   District @relation(fields: [districtId], references: [id])

  villages Village[]

  scopeUsers User[] @relation("UserSubDistrictScope")

  @@unique([districtId, name])
}

// ============================================================
// บัญชีผู้ใช้งานและสิทธิ์การเข้าถึง (RBAC)
// อ้างอิงระเบียบกระทรวงมหาดไทยว่าด้วยการบริหารและการใช้จ่ายเงินโครงการ กข.คจ. พ.ศ. 2553
// ครอบคลุมตั้งแต่ระดับครัวเรือนจนถึงระดับประเทศ (กรมการพัฒนาชุมชน)
// ============================================================

/// บทบาทผู้ใช้งานระดับ Global: จากล่างสุด (ครัวเรือน) ถึงบนสุด (ส่วนกลาง)
/// ลำดับขั้นนี้ตรงกับ ROLE_RANK ใน src/lib/authz.ts ห้ามสลับลำดับโดยไม่แก้ที่นั่นด้วย
enum GlobalRole {
  HOUSEHOLD // ครัวเรือนเป้าหมาย
  VILLAGE_COMMITTEE // คณะกรรมการ กข.คจ. หมู่บ้าน (ดูตำแหน่งย่อยที่ CommitteeRole)
  SUB_DISTRICT_ADMIN // พัฒนากรผู้รับผิดชอบตำบล
  DISTRICT_ADMIN // ผู้บริหารอำเภอ
  PROVINCIAL_ADMIN // ผู้บริหารจังหวัด
  GLOBAL_ADMIN // กรมการพัฒนาชุมชน (ส่วนกลาง)
  IT_SUPPORT // ผู้ดูแลระบบด้านเทคนิค — ไม่ใช่ส่วนหนึ่งของสายบังคับบัญชาภูมิศาสตร์ ไม่มีสิทธิ์เข้าถึงข้อมูลสมุดทะเบียนโครงการ
             // ทั้ง 4 เล่มเด็ดขาด จัดการได้เฉพาะบัญชีผู้ใช้งาน (ดูอย่างเดียว) และ SystemAuditLog เท่านั้น
}

/// ตำแหน่งย่อยของผู้ใช้ที่มี role = VILLAGE_COMMITTEE เท่านั้น
enum CommitteeRole {
  CHAIRMAN // ประธานคณะกรรมการ
  SECRETARY // เลขานุการ
  FINANCE_MEMBER // กรรมการเงินทุน
  NORMAL_MEMBER // กรรมการทั่วไป
}

model User {
  id            Int            @id @default(autoincrement())
  username      String         @unique
  passwordHash  String
  role          GlobalRole
  committeeRole CommitteeRole? // ใช้เฉพาะเมื่อ role = VILLAGE_COMMITTEE
  phoneNumber   String // บังคับกรอกทุก role — ใช้สำหรับส่ง SMS แจ้งเตือน และฟังก์ชัน Click-to-Call
  email         String @unique // บังคับกรอกทุก role — ใช้สำหรับกู้คืนรหัสผ่านด้วย OTP ทางอีเมล
  lineId        String? // LINE userId ของผู้ใช้ — ใช้สำหรับส่งข้อความแจ้งเตือนผ่าน LINE Messaging API (เดิมชื่อ "LINE แจ้งเตือน")
  telegramChatId    String? // Telegram chat_id ของผู้ใช้ — ใช้สำหรับส่งข้อความแจ้งเตือนผ่าน Telegram Bot API
  telegramLinkToken String? @unique // โทเค็นชั่วคราวสำหรับผูกบัญชี Telegram ผ่านลิงก์ t.me/<bot>?start=<token> (เคลียร์ทิ้งหลังผูกสำเร็จ)
  isActive      Boolean  @default(true) // false = ถูกระงับการใช้งาน (soft delete) — ห้าม login อีก

  // ข้อมูลส่วนบุคคล (Profile Separation): User เก็บเฉพาะข้อมูลระบบ/การติดต่อ/พื้นที่เท่านั้น
  // ชื่อ-สกุลและข้อมูลเฉพาะแต่ละบทบาทแยกไปเก็บที่ตาราง *Profile ด้านล่าง (1-to-1 ตาม role)
  householdProfile HouseholdProfile?
  committeeProfile CommitteeProfile?
  officialProfile  OfficialProfile?

  // ผูกบัญชี role HOUSEHOLD เข้ากับครัวเรือนเป้าหมายที่เป็นเจ้าของจริง — ใช้บังคับ data isolation
  // ไม่ให้เห็น/แก้ไขข้อมูลของครัวเรือนอื่นในหมู่บ้านเดียวกัน (แยกจาก scopeVillageId ซึ่งกว้างระดับหมู่บ้าน)
  householdId Int?
  household   TargetHousehold? @relation(fields: [householdId], references: [id])

  // ขอบเขตข้อมูลที่มองเห็นได้ ขึ้นอยู่กับ role: HOUSEHOLD/VILLAGE_COMMITTEE ผูกกับ scopeVillageId,
  // SUB_DISTRICT_ADMIN ผูกกับ scopeSubDistrictId, DISTRICT_ADMIN ผูกกับ scopeDistrictId,
  // PROVINCIAL_ADMIN ผูกกับ scopeProvinceId, GLOBAL_ADMIN ไม่มีขอบเขต (เห็นทั้งหมด)
  scopeVillageId     Int?
  scopeVillage       Village?     @relation(fields: [scopeVillageId], references: [id])
  scopeSubDistrictId Int?
  scopeSubDistrict   SubDistrict? @relation("UserSubDistrictScope", fields: [scopeSubDistrictId], references: [id])
  scopeDistrictId    Int?
  scopeDistrict      District?    @relation("UserDistrictScope", fields: [scopeDistrictId], references: [id])
  scopeProvinceId    Int?
  scopeProvince      Province?    @relation("UserProvinceScope", fields: [scopeProvinceId], references: [id])

  createdAt DateTime @default(now())
  sessions  Session[]

  approvedLoans              Loan[]            @relation("LoanApprovedBy")
  chairmanApprovedTransactions BankTransaction[] @relation("BankTxnChairmanApproval")
  financeApprovedTransactions  BankTransaction[] @relation("BankTxnFinanceApproval")
  requestedBankAccounts        BankAccount[]     @relation("BankAccountRequestedBy")
  chairmanApprovedBankAccounts BankAccount[]     @relation("BankAccountChairmanApproval")
  financeApprovedBankAccounts  BankAccount[]     @relation("BankAccountFinanceApproval")
  notifications               Notification[]
  uploadedMeetingRecords       VillageMeetingRecord[]
  passwordResetOtps            PasswordResetOtp[]
  auditLogs                    SystemAuditLog[]
  pdpaConsents                 PdpaConsent[]
  createdDebtConfirmationRounds DebtConfirmationRound[]
  debtConfirmationsMade         DebtConfirmation[]
  recordedVisitLogs             VisitLog[]
  advisedVisitLogs               VisitLog[] @relation("VisitLogAdvisedBy")
  submittedInquiries            HouseholdInquiry[]
  repliedInquiries              HouseholdInquiry[] @relation("InquiryRepliedBy")
}

/// ข้อมูลส่วนบุคคลของผู้ใช้ role HOUSEHOLD (1-to-1 กับ User, สร้างเมื่อมีการเปิดบัญชีให้ครัวเรือน)
/// เก็บเฉพาะข้อมูลที่ยังไม่มีที่เก็บอื่น — ชื่อ/บ้านเลขที่/จำนวนสมาชิก/รายได้/ลำดับที่ ยังคงอยู่ที่
/// TargetHousehold + HouseholdIncomeRecord (ผ่าน User.household) เพื่อไม่ให้เกิดข้อมูลซ้ำซ้อนกันสองแหล่ง
/// เนื่องจาก TargetHousehold ลงทะเบียนแยกได้ก่อนที่จะมีบัญชีผู้ใช้งานผูกอยู่เสมอ (ดู /households/new)
model HouseholdProfile {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  age               Int? // อายุ ณ วันที่เปิดบัญชี
  occupation        String? // อาชีพปัจจุบัน
  consentPersonName String? // ชื่อผู้ให้ความยินยอม (อ้างอิงสัญญายืมเงิน)
  consentRelation   String? // ความสัมพันธ์กับผู้ให้ความยินยอม เช่น ภรรยา/สามี/ทายาท
  reminderLeadDays  Int      @default(7) // จำนวนวันล่วงหน้าก่อนครบกำหนดชำระที่ต้องการรับแจ้งเตือน (ตั้งเองได้ที่หน้า "บัญชีของฉัน")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// ข้อมูลส่วนบุคคลของผู้ใช้ role VILLAGE_COMMITTEE (1-to-1 กับ User)
/// ไม่เก็บ committeeRole ซ้ำที่นี่ — ใช้ User.committeeRole เป็นแหล่งข้อมูลเดียวเพื่อไม่ให้ข้อมูลเพี้ยนกัน
model CommitteeProfile {
  id               Int          @id @default(autoincrement())
  userId           Int          @unique
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  titlePrefix      TitlePrefix? // คำนำหน้านาม (นาย/นาง/นางสาว/อื่นๆ)
  titlePrefixOther String? // ข้อความคำนำหน้าที่กรอกเอง — ใช้เมื่อ titlePrefix = OTHER เท่านั้น
  firstName        String
  lastName         String
  termStartDate    DateTime? // วันที่เริ่มวาระ
  termEndDate      DateTime? // วันที่สิ้นสุดวาระ
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

/// ข้อมูลส่วนบุคคลของเจ้าหน้าที่รัฐ (SUB_DISTRICT_ADMIN ขึ้นไป) (1-to-1 กับ User)
model OfficialProfile {
  id               Int          @id @default(autoincrement())
  userId           Int          @unique
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  titlePrefix      TitlePrefix? // คำนำหน้านาม (นาย/นาง/นางสาว/อื่นๆ)
  titlePrefixOther String? // ข้อความคำนำหน้าที่กรอกเอง — ใช้เมื่อ titlePrefix = OTHER เท่านั้น
  firstName        String
  lastName         String
  positionTitle    String? // ตำแหน่งทางการ
  handoverDate     DateTime? // วันที่รับมอบงาน (อ้างอิงสมุดเล่มน้ำตาล)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

/// ประเภทการแจ้งเตือนในระบบ (In-app Notification)
enum NotificationType {
  ALERT // แจ้งเตือนเร่งด่วน เช่น รายชื่อครัวเรือนที่เลยกำหนดชำระหนี้
  REMINDER // แจ้งเตือนล่วงหน้า เช่น สรุปยอดที่ต้องชำระประจำเดือน
}

/// การแจ้งเตือนภายในระบบ (In-app Notification) แสดงผลผ่าน "กระดิ่งแจ้งเตือน" ที่ Top Navigation Bar
model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  link      String? // เส้นทาง (relative URL) สำหรับ deep-link ไปยังหน้า/รายการที่เกี่ยวข้องเมื่อคลิก
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

model Session {
  id        String   @id @default(cuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ============================================================
// Master Data
// ============================================================

/// ข้อมูลหมู่บ้านที่เข้าร่วมโครงการ กข.คจ. (เล่มน้ำตาล ส่วนที่ 1: ทะเบียนหมู่บ้านระดับอำเภอ)
model Village {
  id            Int      @id @default(autoincrement())
  registryNo    Int? // ลำดับเลขที่ประจำหมู่บ้าน (เรียงตามปีงบประมาณ)
  villageNo     String // หมู่ที่
  villageName   String // ชื่อหมู่บ้าน
  subDistrictId Int
  subDistrict   SubDistrict @relation(fields: [subDistrictId], references: [id])
  budgetYear    Int // ปี พ.ศ. ที่ได้รับงบประมาณ (ครั้งแรก)
  budgetAmount  Float? // จำนวนเงินงบประมาณที่ได้รับ (บาท)
  latitude      Float? // พิกัดละติจูด — ใช้แสดงหมุดในแท็บ "มุมมองแผนที่" (Smart Report & Map Center)
  longitude     Float? // พิกัดลองจิจูด
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  households        TargetHousehold[]
  committeeMembers  CommitteeMember[]
  workerAssignments DevelopmentWorkerAssignment[]
  visitLogs         VisitLog[]
  bankAccounts      BankAccount[]
  handovers         VillageHandover[]
  statusSnapshots   VillageStatusSnapshot[]
  scopeUsers        User[]
  assignments       VillageAssignment[]
  meetingRecords    VillageMeetingRecord[]
  debtConfirmationRounds DebtConfirmationRound[]
  auditLogs         SystemAuditLog[]
  inquiries         HouseholdInquiry[]

  @@unique([villageNo, subDistrictId])
}

/// ครัวเรือนเป้าหมาย (เล่มม่วง หน้า 1: บัญชีทะเบียนครัวเรือนเป้าหมาย)
/// คำนำหน้าชื่อหัวหน้าครัวเรือน — เก็บเป็นค่าคงที่ 3 แบบ หรือ OTHER เมื่อกรอกเอง (ดู titlePrefixOther)
enum TitlePrefix {
  MR // นาย
  MRS // นาง
  MISS // นางสาว
  OTHER // อื่นๆ (ดูข้อความจริงที่ titlePrefixOther)
}

enum Gender {
  MALE // ชาย
  FEMALE // หญิง
}

model TargetHousehold {
  id                Int      @id @default(autoincrement())
  villageId         Int
  village           Village  @relation(fields: [villageId], references: [id])
  sequenceNo        Int // ลำดับที่ครัวเรือนเป้าหมาย (เรียงรายได้น้อยไปมาก)
  titlePrefix       TitlePrefix? // คำนำหน้าชื่อหัวหน้าครัวเรือน (นาย/นาง/นางสาว/อื่นๆ)
  titlePrefixOther  String? // ข้อความคำนำหน้าที่กรอกเอง — ใช้เมื่อ titlePrefix = OTHER เท่านั้น
  headFirstName     String // ชื่อหัวหน้าครัวเรือน
  headLastName      String // นามสกุลหัวหน้าครัวเรือน
  gender            Gender? // เพศของหัวหน้าครัวเรือน
  birthDate         DateTime? // วันเดือนปีเกิด — ใช้คำนวณอายุปัจจุบันอัตโนมัติตอนยื่นแบบเสนอโครงการ/ขอยืมเงินทุน
  occupation        String? // อาชีพ — ดึงไปเติมอัตโนมัติในแบบเสนอโครงการ/แบบขอยืมเงินทุน (แก้ไขทับได้)
  specialSkills     String? // ความสามารถพิเศษ
  phoneNumber       String? // เบอร์โทรศัพท์ครัวเรือน — เห็นได้เฉพาะบางบทบาทเท่านั้น (ดู canViewHouseholdPhoneNumber ใน lib/authz.ts)
  houseNo           String? // บ้านเลขที่
  memberCount       Int? // จำนวนสมาชิกในครัวเรือน
  incomeBeforeLoan  Float? // รายได้เฉลี่ยต่อคนต่อปีตามเกณฑ์ จปฐ. ก่อนยืมเงิน (บาท)
  isDefaulted       Boolean  @default(false) // ครัวเรือนผิดสัญญา (เล่มน้ำตาล ส่วนที่ 3)
  defaultedAmount   Float? // จำนวนเงินที่ผิดสัญญา (บาท)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  incomeRecords HouseholdIncomeRecord[]
  loans         Loan[]
  proposals     ProjectProposal[]
  loanRequests  LoanRequest[]
  users         User[] // บัญชีผู้ใช้ role HOUSEHOLD ที่ผูกกับครัวเรือนนี้ (สำหรับ data isolation)
  debtConfirmations DebtConfirmation[]
  inquiries     HouseholdInquiry[]

  @@unique([villageId, sequenceNo])
}

/// รายได้เฉลี่ยภายหลังรับเงินยืม ภายหลัง 1/2/3 ปี (เล่มม่วง หน้า 1)
model HouseholdIncomeRecord {
  id             Int             @id @default(autoincrement())
  householdId    Int
  household      TargetHousehold @relation(fields: [householdId], references: [id], onDelete: Cascade)
  yearsAfterLoan Int // ภายหลังรับเงินยืม 1 / 2 / 3 ปี
  income         Float // รายได้เฉลี่ยต่อคนต่อปี (บาท)

  @@unique([householdId, yearsAfterLoan])
}

/// คณะกรรมการ กข.คจ. หมู่บ้าน ผู้รับผิดชอบเงินทุน (เล่มม่วง ท้ายเล่ม)
model CommitteeMember {
  id        Int       @id @default(autoincrement())
  villageId Int
  village   Village   @relation(fields: [villageId], references: [id])
  setNo     Int? // ชุดที่
  name      String // ชื่อ-สกุล
  position  String? // ตำแหน่ง
  startDate DateTime? // วันเดือนปี เริ่มรับผิดชอบ
  endDate   DateTime? // วันเดือนปี สิ้นสุดรับผิดชอบ
}

/// พัฒนากรผู้รับผิดชอบหมู่บ้าน กข.คจ. (เล่มม่วง ท้ายเล่ม)
model DevelopmentWorkerAssignment {
  id        Int       @id @default(autoincrement())
  villageId Int
  village   Village   @relation(fields: [villageId], references: [id])
  name      String // ชื่อ-สกุล
  position  String? // ตำแหน่ง
  startDate DateTime? // วันเดือนปี เริ่มรับผิดชอบ
  endDate   DateTime? // วันเดือนปี สิ้นสุดรับผิดชอบ
}

/// บันทึกการติดตาม ตรวจสอบ และให้ข้อแนะนำของเจ้าหน้าที่ (เล่มม่วง ท้ายเล่ม) — ใช้เป็นหลักฐานการลงพื้นที่ปฏิบัติงาน
/// ของพัฒนากรตำบล (เช่น ร่วมประชุม ติดตามหนี้สิน) พร้อมแนบเอกสาร/ภาพถ่ายประกอบได้หลายไฟล์ต่อรายการ
/// สร้าง/ลบได้เฉพาะพัฒนากรตำบล (SUB_DISTRICT_ADMIN) เจ้าของบันทึกเท่านั้น — ดูได้ทุก role ตั้งแต่ระดับตำบลขึ้นไป
/// ตามเขตพื้นที่ (ดู lib/authz.ts: canCreateVisitLog/canViewVisitLogBook)
model VisitLog {
  id           Int      @id @default(autoincrement())
  villageId    Int
  village      Village  @relation(fields: [villageId], references: [id])
  visitDate    DateTime // วันเดือนปีที่ติดตาม
  visitType    String // ประเภทการลงพื้นที่ เช่น "ร่วมประชุม", "ติดตามหนี้สิน", "ตรวจเยี่ยมครัวเรือน", "อื่นๆ"
  visitorName  String // ชื่อ/สกุลผู้ติดตาม
  visitorTitle String? // ตำแหน่งผู้ติดตาม
  notes        String? // ประเด็นที่ติดตามและข้อสังเกตแนะนำ
  recordedById Int
  recordedBy   User     @relation(fields: [recordedById], references: [id])
  advice       String? // คำแนะนำจากพัฒนาการอำเภอ/พัฒนาการจังหวัด — เห็นได้ทุกฝ่ายที่มีสิทธิ์ดูบันทึกนี้ (canViewVillageStatusBook)
  advisedById  Int?
  advisedBy    User?     @relation("VisitLogAdvisedBy", fields: [advisedById], references: [id])
  advisedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attachments VisitLogAttachment[]
}

/// เอกสาร/ภาพถ่ายแนบประกอบบันทึกการติดตามแต่ละรายการ (แนบได้หลายไฟล์ต่อ 1 บันทึก)
model VisitLogAttachment {
  id         Int      @id @default(autoincrement())
  visitLogId Int
  visitLog   VisitLog @relation(fields: [visitLogId], references: [id], onDelete: Cascade)
  fileUrl    String
  createdAt  DateTime @default(now())
}

// ============================================================
// พัฒนากรและการส่งมอบ-รับมอบงาน (เวอร์ชันปรับโครงสร้างใหม่ให้เป็น relation จริง
// แทนการเก็บชื่อเป็น string ตรงๆ อย่าง DevelopmentWorkerAssignment/VillageHandover ด้านบน)
// อ้างอิง เล่มม่วง: รายชื่อพัฒนากร ผู้รับผิดชอบ หมู่บ้าน กข.คจ. / เล่มน้ำตาล ส่วนที่ 2: บันทึกการส่งมอบและรับมอบ
// ============================================================

/// ข้อมูลพัฒนากร (เล่มม่วง ท้ายเล่ม: รายชื่อพัฒนากร ผู้รับผิดชอบ หมู่บ้าน กข.คจ.)
model Developer {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  position  String? // ตำแหน่ง
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments       VillageAssignment[]
  sentHandovers     HandoverLog[]       @relation("HandoverSender")
  receivedHandovers HandoverLog[]       @relation("HandoverReceiver")
}

/// ประวัติการรับผิดชอบหมู่บ้านของพัฒนากรแต่ละคน (เล่มม่วง ท้ายเล่ม)
model VillageAssignment {
  id          Int       @id @default(autoincrement())
  developerId Int
  developer   Developer @relation(fields: [developerId], references: [id])
  villageId   Int
  village     Village   @relation(fields: [villageId], references: [id])
  startDate   DateTime // วันเดือนปี เริ่มรับผิดชอบ
  endDate     DateTime? // วันเดือนปี สิ้นสุดรับผิดชอบ
  status      String    @default("ACTIVE") // "ACTIVE" | "TRANSFERRED"
}

/// บันทึกการส่งมอบ-รับมอบงานระหว่างพัฒนากร (เล่มน้ำตาล ส่วนที่ 2: บันทึกการส่งมอบและรับมอบ)
model HandoverLog {
  id           Int       @id @default(autoincrement())
  handoverDate DateTime
  senderId     Int
  sender       Developer @relation("HandoverSender", fields: [senderId], references: [id])
  receiverId   Int
  receiver     Developer @relation("HandoverReceiver", fields: [receiverId], references: [id])
  villageCount Int // จำนวนหมู่บ้านที่ส่งมอบ
  notes        String?
}

// ============================================================
// Transactions
// ============================================================

/// สถานะการอนุมัติ ใช้ร่วมกันสำหรับ Loan (อนุมัติโดย CHAIRMAN) และ BankTransaction (multi-signature)
enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

/// สถานะเครดิต/ความเสี่ยงของเงินยืมแต่ละก้อน คำนวณอัตโนมัติจาก dueDate ทุกวัน (ดู src/lib/risk.ts)
/// และรีเซ็ตกลับเป็น NORMAL อัตโนมัติเมื่อมีการอนุมัติรับชำระเงิน หรือรีเซ็ตด้วยตนเองผ่าน /api/households/[id]/reset-credit
enum RiskStatus {
  NORMAL // ปกติ — ยังไม่ถึงกำหนดชำระ (เกิน 15 วันก่อนครบกำหนด) หรือชำระตรงตามงวด
  WATCHLIST // เฝ้าระวัง — ใกล้ถึงกำหนดชำระใน 15 วัน หรือเลยกำหนดมาไม่เกิน 30 วัน
  HIGH_RISK // เสี่ยงสูง/ผิดสัญญา — เลยกำหนดชำระเกิน 30 วัน
}

/// การยืมเงินทุนของครัวเรือนเป้าหมายแต่ละครั้ง (เล่มม่วง: ข้อมูลการยืมเงินทุน / เล่มเหลือง: บัญชีคุมลูกหนี้)
/// สิทธิ์: SECRETARY สร้าง/แก้ไขได้ (canCreateOrUpdateLoan), CHAIRMAN อนุมัติได้ (canApproveLoan) — ดู src/lib/authz.ts
model Loan {
  id                 Int      @id @default(autoincrement())
  householdId        Int
  household          TargetHousehold @relation(fields: [householdId], references: [id])
  borrowRound        Int // ยืมครั้งที่ (1, 2, 3, ...)
  contractNo         String? // เลขที่สัญญายืมเงิน
  amount             Float // จำนวนเงินยืม (บาท)
  receivedDate       DateTime // วัน/เดือน/ปี ที่รับเงินยืม
  dueDate            DateTime? // วัน/เดือน/ปี คืนเงินครั้งสุดท้ายตามสัญญา
  occupation         String? // อาชีพที่ยืมเงินไปลงทุน
  outstandingBalance Float // ยอดค้างชำระคงเหลือ (บาท)
  isClosed           Boolean  @default(false) // ปิดสัญญาแล้ว (คืนครบแล้ว)

  approvalStatus ApprovalStatus @default(PENDING) // อนุมัติโดยประธานคณะกรรมการ (CHAIRMAN)
  approvedById   Int?
  approvedBy     User?          @relation("LoanApprovedBy", fields: [approvedById], references: [id])
  approvedAt     DateTime?

  riskStatus RiskStatus @default(NORMAL) // ประเมินความเสี่ยง/จัดลำดับเครดิต — คำนวณอัตโนมัติจาก dueDate (ดู src/lib/risk.ts)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  repayments LoanRepayment[]

  @@unique([householdId, borrowRound])
}

/// การรับคืนเงินยืมแต่ละงวด (เล่มเหลือง: บัญชีคุมลูกหนี้ - รายการรับคืนเงิน)
model LoanRepayment {
  id            Int      @id @default(autoincrement())
  loanId        Int
  loan          Loan     @relation(fields: [loanId], references: [id])
  receiptNo     String? // เลขที่ใบสำคัญรับเงิน
  paymentDate   DateTime // วัน/เดือน/ปี ที่คืนเงิน
  amount        Float // จำนวนเงินที่คืน (บาท)
  note          String?
  transferSlipUrl String? // URL รูปภาพสลิปโอนเงิน (หลักฐานการรับชำระ)

  // เวิร์กโฟลว์ "แจ้งชำระเงิน" ของครัวเรือน: รายการที่เลขาฯ/ฝ่ายการเงินคีย์ตรงถือว่า APPROVED ทันที (ค่าเริ่มต้น)
  // ส่วนรายการที่ครัวเรือนแจ้งเองผ่าน /api/household/payments จะเริ่มที่ PENDING เสมอ จนกว่าจะถูกตรวจสอบ
  // (recomputeLoanBalance นับรวมเฉพาะ APPROVED เท่านั้น — ดู src/lib/ledger.ts)
  status          ApprovalStatus @default(APPROVED)
  householdNote   String? // หมายเหตุ/ข้อความถึงกรรมการ ที่ครัวเรือนพิมพ์ตอนแจ้งชำระเงิน
  committeeReply  String? // ข้อความตอบกลับจากกรรมการ (เช่น เหตุผลที่ปฏิเสธ)

  createdAt     DateTime @default(now())
}

/// บัญชีเงินฝากธนาคารของหมู่บ้าน (เล่มเขียว: บัญชีคุมเงินฝากธนาคาร)
/// การเปิดบัญชีธนาคารใหม่ต้องผ่าน Multi-signature เช่นเดียวกับรายการถอนเงิน (ดู BankTransaction ด้านล่าง):
/// CHAIRMAN ลงนาม 1 เสียง + FINANCE_MEMBER อย่างน้อย 1 เสียง คนละคนกัน ก่อนถือว่าเปิดบัญชีสมบูรณ์
/// (isFullyApproved = ทั้งสองฟิลด์ไม่เป็น null) — ระหว่างรอลงนามยังบันทึกรายการฝาก-ถอนไม่ได้ ดู src/lib/authz.ts
model BankAccount {
  id          Int    @id @default(autoincrement())
  villageId   Int
  village     Village @relation(fields: [villageId], references: [id])
  bankName    String? // ชื่อธนาคาร
  branch      String? // สาขา
  accountNo   String? // เลขที่บัญชี
  accountName String? // ชื่อบัญชี

  requestedById Int
  requestedBy   User @relation("BankAccountRequestedBy", fields: [requestedById], references: [id])

  chairmanApprovedById Int?
  chairmanApprovedBy   User?     @relation("BankAccountChairmanApproval", fields: [chairmanApprovedById], references: [id])
  chairmanApprovedAt   DateTime?
  financeApprovedById  Int?
  financeApprovedBy    User?     @relation("BankAccountFinanceApproval", fields: [financeApprovedById], references: [id])
  financeApprovedAt    DateTime?

  createdAt DateTime @default(now())

  transactions BankTransaction[]
}

/// รายการฝาก/ถอนเงินในบัญชีเงินฝากธนาคาร (เล่มเขียว)
/// รายการถอนต้องผ่าน Multi-signature: CHAIRMAN ลงนาม 1 เสียง + FINANCE_MEMBER อย่างน้อย 1 เสียง
/// ก่อนถือว่าอนุมัติ (isFullyApproved = ทั้งสองฟิลด์ไม่เป็น null) — ดู src/lib/authz.ts
model BankTransaction {
  id              Int         @id @default(autoincrement())
  bankAccountId   Int
  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id])
  transactionDate DateTime // วัน เดือน ปี
  documentNo      String? // เลขที่เอกสาร (ใบสำคัญรับเงิน/เลขที่บัญชีผู้ยืม)
  description     String // รายการ
  depositAmount   Float       @default(0) // ฝาก (บาท)
  withdrawAmount  Float       @default(0) // ถอน (บาท)
  balance         Float // คงเหลือ (บาท)
  note            String? // หมายเหตุ
  passbookImageUrl String? // URL รูปภาพสมุดบัญชีธนาคาร (หลักฐานประกอบรายการ)

  chairmanApprovedById Int?
  chairmanApprovedBy   User?     @relation("BankTxnChairmanApproval", fields: [chairmanApprovedById], references: [id])
  chairmanApprovedAt   DateTime?
  financeApprovedById  Int?
  financeApprovedBy    User?     @relation("BankTxnFinanceApproval", fields: [financeApprovedById], references: [id])
  financeApprovedAt    DateTime?

  createdAt       DateTime    @default(now())
}

/// บันทึกการส่งมอบ-รับมอบเงินทุนหมู่บ้าน กข.คจ. เมื่อมีการโยกย้ายเจ้าหน้าที่ (เล่มน้ำตาล ส่วนที่ 2)
model VillageHandover {
  id           Int      @id @default(autoincrement())
  villageId    Int
  village      Village  @relation(fields: [villageId], references: [id])
  handoverNo   Int // ครั้งที่
  fromName     String // ชื่อผู้ส่งมอบ
  fromPosition String? // ตำแหน่งผู้ส่งมอบ
  toName       String // ชื่อผู้รับมอบ
  toPosition   String? // ตำแหน่งผู้รับมอบ
  handoverDate DateTime // วัน เดือน ปี ที่ส่งมอบ-รับมอบ

  statusSnapshots VillageStatusSnapshot[]
}

/// ข้อมูลและสถานะของหมู่บ้าน ณ เวลาส่งมอบ-รับมอบแต่ละครั้ง (เล่มน้ำตาล ส่วนที่ 3)
model VillageStatusSnapshot {
  id                     Int              @id @default(autoincrement())
  villageId              Int
  village                Village          @relation(fields: [villageId], references: [id])
  handoverId             Int?
  handover               VillageHandover? @relation(fields: [handoverId], references: [id])
  totalHouseholds        Int // ครัวเรือนเป้าหมายทั้งหมด
  householdsReceivedLoan Int // ครัวเรือนที่ได้รับเงินยืมแล้ว
  householdsRepaying     Int // ครัวเรือนที่อยู่ในระหว่างคืนเงินยืม
  fundWithHouseholds     Float // เงินทุนอยู่ที่ครัวเรือนเป้าหมาย (บาท)
  fundInBankAccount      Float // เงินทุนอยู่ในบัญชีเงินฝาก กข.คจ. (บาท)
  fundElsewhere          Float // เงินทุนอยู่ที่อื่นๆ (บาท)
  purpleBookExists       Boolean // มีสมุดบัญชีทะเบียนครัวเรือนเป้าหมาย (เล่มม่วง)
  purpleBookCorrect      Boolean?
  greenBookExists        Boolean // มีสมุดบัญชีคุมเงินฝากธนาคาร (เล่มเขียว)
  greenBookCorrect       Boolean?
  yellowBookExists       Boolean // มีสมุดบัญชีคุมลูกหนี้ (เล่มเหลือง)
  yellowBookCorrect      Boolean?
  hasDefaultedHouseholds Boolean // มีครัวเรือนเป้าหมายผิดสัญญา
  defaultedAmount        Float?
  note                   String?
  recordedAt             DateTime         @default(now())
}

// ============================================================
// เอกสารแบบฟอร์ม (แบบเสนอโครงการ / แบบขอยืมเงินทุน)
// ============================================================

/// แบบเสนอโครงการของครัวเรือนเป้าหมาย (แบบแนบท้ายระเบียบฯ พ.ศ. 2553 หมวด 4 ข้อ 16)
model ProjectProposal {
  id             Int             @id @default(autoincrement())
  householdId    Int
  household      TargetHousehold @relation(fields: [householdId], references: [id])
  volumeNo       String? // เล่มที่
  proposalNo     String? // โครงการที่
  applicantAge   Int // อายุผู้เสนอโครงการ ณ วันที่ยื่น (ปี)
  occupation     String // อาชีพ
  projectName    String // ชื่อโครงการที่เสนอ
  totalAmount    Float // เป็นเงินทั้งสิ้น (บาท)
  proposedDate   DateTime // วันที่ผู้เสนอโครงการลงนาม

  // ความเห็นของพัฒนากรผู้รับผิดชอบประจำตำบล
  workerOpinion  String? // "possible" | "not_possible"
  workerReason   String?
  workerName     String?
  workerDate     DateTime?

  // ผลการพิจารณาอนุมัติของคณะกรรมการ กข.คจ. หมู่บ้าน
  committeeDecision  String? // "approved" | "rejected"
  committeeAmount    Float?
  committeeReason    String?
  committeeChairName String?
  committeeDate      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ProjectProposalItem[]
}

/// รายการย่อยของแบบเสนอโครงการ (ข้อ 2.1, 2.2, 2.3, ...)
model ProjectProposalItem {
  id          Int             @id @default(autoincrement())
  proposalId  Int
  proposal    ProjectProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  itemNo      Int // ลำดับรายการ (2.1, 2.2, ...)
  description String // รายการ
  amount      Float // เป็นเงิน (บาท)
}

/// แบบขอยืมเงินทุนของครัวเรือนเป้าหมาย (แบบแนบท้ายระเบียบฯ พ.ศ. 2553 หมวด 4 ข้อ 16)
model LoanRequest {
  id                Int             @id @default(autoincrement())
  householdId       Int
  household         TargetHousehold @relation(fields: [householdId], references: [id])
  volumeNo          String? // เล่มที่
  requestNo         String? // เลขที่
  applicantAge      Int // อายุข้าพเจ้า ณ วันที่ยื่น (ปี)
  occupation        String // อาชีพ
  requestedAmount   Float // ขอยืมเงินทุนเป็นเงินทั้งสิ้น (บาท)
  agreesToRegulations Boolean @default(false) // ยินยอมปฏิบัติตามระเบียบกระทรวงมหาดไทยฯ
  spouseConsentName String? // ชื่อภรรยา/สามี/ทายาท ผู้ให้คำยินยอม
  requestDate       DateTime // วันที่ลงนามขอยืม

  // ความเห็นของพัฒนากรผู้รับผิดชอบประจำตำบล
  workerOpinion String? // "agree" | "disagree"
  workerReason  String?
  workerName    String?
  workerDate    DateTime?

  // ผลการพิจารณาอนุมัติเงินยืมของคณะกรรมการ กข.คจ. หมู่บ้าน
  committeeDecision  String? // "approved" | "rejected"
  committeeAmount    Float?
  committeeReason    String?
  committeeChairName String?
  committeeDate      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// วาระการประชุมและมติคณะกรรมการ กข.คจ. หมู่บ้าน (Meeting Records) — เก็บไฟล์แนบ (.pdf/.jpg/.png) เพื่อความโปร่งใส
/// สร้าง/อัปโหลดได้เฉพาะประธาน/เลขานุการ/ฝ่ายการเงินของหมู่บ้านตนเอง — ดูได้ทุกคนตามเขตพื้นที่ (Area-Based Isolation)
/// ลบได้เฉพาะพัฒนากรประจำตำบล (SUB_DISTRICT_ADMIN) เท่านั้น — ดู lib/authz.ts (canCreateMeetingRecord/canDeleteMeetingRecord)
model VillageMeetingRecord {
  id           Int      @id @default(autoincrement())
  villageId    Int
  village      Village  @relation(fields: [villageId], references: [id])
  meetingDate  DateTime // วันที่ประชุม
  agendaTopic  String // หัวข้อวาระการประชุม
  fileUrl      String // URL ไฟล์แนบ (.pdf/.jpg/.png) — อัปโหลดผ่าน /api/uploads ก่อนแล้วส่ง URL มาที่นี่
  uploadedById Int
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// รอบยืนยันยอดหนี้ประจำปี — ประธานคณะกรรมการ (CHAIRMAN) กำหนดวันเริ่มยืนยันยอดของหมู่บ้านตนเองในแต่ละปี
/// (ปี พ.ศ.) ครัวเรือนยืนยันยอดหนี้รวมของตนได้ตั้งแต่วันที่กำหนดเป็นต้นไป จนกว่าจะมีการสร้างรอบของปีถัดไป
model DebtConfirmationRound {
  id               Int      @id @default(autoincrement())
  villageId        Int
  village          Village  @relation(fields: [villageId], references: [id])
  year             Int // ปี พ.ศ. ที่ยืนยันยอด
  confirmationDate DateTime // วันที่ประธานกรรมการกำหนดให้เริ่มยืนยันยอดของปีนี้
  createdById      Int
  createdBy        User     @relation(fields: [createdById], references: [id])
  createdAt        DateTime @default(now())

  confirmations DebtConfirmation[]

  @@unique([villageId, year])
}

/// การยืนยันยอดหนี้รวมของครัวเรือนหนึ่งๆ ต่อรอบยืนยันยอดหนึ่งๆ (ยืนยันยอดคงเหลือรวมทุกเงินยืมที่ยังไม่ปิดสัญญา
/// ในครั้งเดียว ไม่แยกยืนยันทีละเงินยืม) — เก็บสำเนายอด ณ ขณะยืนยันไว้เป็นหลักฐาน แม้ยอดจริงจะเปลี่ยนภายหลัง
model DebtConfirmation {
  id                Int                   @id @default(autoincrement())
  roundId           Int
  round             DebtConfirmationRound @relation(fields: [roundId], references: [id])
  householdId       Int
  household         TargetHousehold       @relation(fields: [householdId], references: [id])
  confirmedById     Int
  confirmedBy       User                  @relation(fields: [confirmedById], references: [id])
  outstandingTotal  Float // ยอดหนี้คงเหลือรวมทุกเงินยืม ณ ขณะยืนยัน
  agreesWithBalance Boolean // true = ยืนยันว่ายอดถูกต้อง, false = แจ้งว่ายอดไม่ตรง (มีข้อโต้แย้ง)
  note              String? // หมายเหตุ/รายละเอียดข้อโต้แย้ง (กรอกเมื่อ agreesWithBalance = false)
  confirmedAt       DateTime @default(now())

  @@unique([roundId, householdId])
}

/// รหัส OTP ชั่วคราวสำหรับกู้คืนรหัสผ่านทางอีเมล (Self-Service Password Reset) — หมดอายุใน 5 นาทีตามที่กำหนด
/// เก็บเฉพาะค่า hash ของ OTP (ไม่เก็บรหัส 6 หลักตัวจริง) เช่นเดียวกับการเก็บรหัสผ่าน — ดู lib/otp.ts
model PasswordResetOtp {
  id         Int       @id @default(autoincrement())
  userId     Int
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  otpHash    String
  expiresAt  DateTime
  consumedAt DateTime? // null = ยังไม่ถูกใช้ — ใช้แล้วต้องไม่ใช้ซ้ำได้อีก
  createdAt  DateTime  @default(now())
}

/// ประวัติเหตุการณ์ด้านความปลอดภัย (Login/OTP/CAPTCHA/LINE) — ใช้ตรวจสอบความผิดปกติย้อนหลัง
/// userId/username เป็น null ได้ (เช่น พยายาม login ด้วย username ที่ไม่มีอยู่จริงในระบบ)
/// villageId เติมอัตโนมัติจาก scopeVillageId ของผู้ใช้ที่ก่อเหตุการณ์ (เฉพาะ role ที่ผูกกับหมู่บ้านเดียว คือ
/// VILLAGE_COMMITTEE/HOUSEHOLD) — ใช้เป็นขอบเขตให้พัฒนากรตำบล/ผู้บริหารอำเภอ/จังหวัด กรองดูเฉพาะพื้นที่ของตน
/// (ดู logAuditEvent ใน lib/auditLog.ts และ canViewAuditLog/getAuditLogScope ใน lib/authz.ts)
/// เหตุการณ์ที่ผู้ก่อเหตุเป็นระดับพัฒนากรตำบลขึ้นไปหรือ IT_SUPPORT จะมี villageId เป็น null — เห็นได้เฉพาะ
/// ส่วนกลาง (GLOBAL_ADMIN) และ IT_SUPPORT เท่านั้น
model SystemAuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String? // ชื่อผู้ใช้ที่พยายาม (เก็บไว้แม้ไม่พบบัญชีจริง เพื่อตรวจสอบการโจมตี)
  action    String // เช่น "LOGIN_SUCCESS", "LOGIN_FAILED_CREDENTIALS", "LOGIN_FAILED_CAPTCHA", "FORGOT_PASSWORD_REQUESTED", "PASSWORD_RESET_SUCCESS", "PASSWORD_RESET_FAILED", "LINE_LINKED"
  detail    String?
  ipAddress String?
  villageId Int?
  village   Village? @relation(fields: [villageId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([villageId])
}

/// หลักฐานการให้ความยินยอมตาม พ.ร.บ.คุ้มครองข้อมูลส่วนบุคคล พ.ศ. 2562 (PDPA) ของผู้ใช้แต่ละคน
/// เก็บเป็นประวัติ (ไม่ overwrite) — ถ้าแก้ไขข้อความนโยบายในอนาคตแล้วขึ้น policyVersion ใหม่ ผู้ใช้ต้องกดยินยอมซ้ำ
/// (ดู src/lib/pdpa.ts: PDPA_POLICY_VERSION) การบล็อกการใช้งานจนกว่าจะยินยอม ทำที่ src/app/layout.tsx
model PdpaConsent {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  policyVersion String // เวอร์ชันข้อความนโยบายที่ยินยอม ณ ขณะนั้น เช่น "1.0"
  acceptedAt    DateTime @default(now())
  ipAddress     String?

  @@index([userId, policyVersion])
}

/// หัวข้อคำร้อง "ปรึกษา/ร้องทุกข์" ที่ครัวเรือนเป้าหมายส่งถึงผู้บริหารอำเภอ/จังหวัด
enum InquiryTopic {
  CONSULT // ปรึกษา
  COMPLAINT // ร้องทุกข์
  OTHER // อื่นๆ (ดูข้อความจริงที่ topicOther)
}

/// สถานะการดำเนินการของคำร้อง — อัปเดตได้เฉพาะพัฒนาการอำเภอ/พัฒนาการจังหวัด (ดู canViewHouseholdInquiries)
/// ไม่มีค่าเริ่มต้น (null = ยังไม่ดำเนินการ) จนกว่าผู้ดูแลจะเข้ามาอัปเดตครั้งแรก
enum InquiryStatus {
  IN_PROGRESS // กำลังแก้ไข
  RESOLVED // เรียบร้อยแล้ว
  OTHER // อื่นๆ (ดูข้อความจริงที่ statusOther)
}

/// เมนู "ปรึกษา/ร้องทุกข์" — ครัวเรือนเป้าหมายส่งข้อความถึงพัฒนาการอำเภอ/พัฒนาการจังหวัดในเขตพื้นที่ของตนเอง
/// เพื่อการพัฒนาบริการต่างๆ ให้ดีขึ้น villageId เก็บซ้ำจาก household.villageId (denormalized) เพื่อกรองตามเขต
/// พื้นที่ (scopeWhereDirect ใน lib/scope.ts) ได้โดยตรงโดยไม่ต้อง join ผ่าน household ทุกครั้ง
model HouseholdInquiry {
  id            Int             @id @default(autoincrement())
  householdId   Int
  household     TargetHousehold @relation(fields: [householdId], references: [id])
  villageId     Int
  village       Village         @relation(fields: [villageId], references: [id])
  topic         InquiryTopic
  topicOther    String? // ข้อความหัวข้อที่กรอกเอง — ใช้เมื่อ topic = OTHER เท่านั้น
  details       String
  attachmentUrl String? // ไฟล์/รูปภาพประกอบ (ถ้ามี) — ดู src/app/api/uploads/route.ts
  submittedById Int
  submittedBy   User            @relation(fields: [submittedById], references: [id])
  status        InquiryStatus?
  statusOther   String? // ข้อความสถานะที่กรอกเอง — ใช้เมื่อ status = OTHER เท่านั้น
  reply         String? // ข้อความตอบกลับจากพัฒนาการอำเภอ/พัฒนาการจังหวัด — ครัวเรือนเห็นได้
  repliedById   Int?
  repliedBy     User?           @relation("InquiryRepliedBy", fields: [repliedById], references: [id])
  repliedAt     DateTime?
  createdAt     DateTime        @default(now())

  @@index([villageId])
}
